{
  "name": "dani-boy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter @dani-boy/web build",
    "dev": "pnpm --parallel --stream --filter @dani-boy/api --filter @dani-boy/web dev",
    "lint": "pnpm -r lint",
    "start": "pnpm --filter @dani-boy/api start",
    "test": "pnpm --filter @dani-boy/api test"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0"
  }
}
